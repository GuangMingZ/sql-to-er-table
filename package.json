{
  "name": "sql-to-er-table",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "description": "A fullstack web application framework based on Express + React + Vite",
  "scripts": {
    "start": "tsx ./server/server.ts",
    "dev": "NODE_ENV=development tsx watch --ignore ./vite.config.**.mjs --ignore ./client --clear-screen=false --inspect=9442 ./server/server.ts",
    "build:client": "cd ./client && vite build",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "prepare": "husky"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "antd": "^6.3.5",
    "classnames": "^2.5.1",
    "cookie-parser": "^1.4.7",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "less": "^4.2.2",
    "lodash": "^4.17.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0",
    "vite-plugin-tsconfig-paths": "^1.4.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings 0"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.3",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "less": "^4.2.2",
    "lint-staged": "^16.2.7",
    "tsc-files": "^1.1.4",
    "tsx": "^4.21.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^7.2.0"
  },
  "overrides": {
    "form-data": "^2.5.4",
    "tough-cookie": "^4.1.3",
    "cookie": "^0.7.0",
    "fast-redact": "^5.0.0",
    "generator-function": "1.0.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.54.0"
  }
